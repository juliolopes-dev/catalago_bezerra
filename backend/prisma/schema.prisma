generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Usuários do catálogo (admin, vendedor, cliente)
// ─────────────────────────────────────────

model usuarios_catalogo {
  id           Int       @id @default(autoincrement())
  nome         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  senha        String    @db.VarChar(255)
  perfil       String    @default("cliente") // 'admin' | 'vendedor' | 'cliente'
  empresa      String?   @db.VarChar(255)
  tabela_preco String    @default("preco2") @db.VarChar(10) // 'preco2' | 'preco3' | 'preco4'
  ativo        Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamp()
  updated_at   DateTime  @updatedAt @db.Timestamp()
  deleted_at   DateTime? @db.Timestamp()
}

// ─────────────────────────────────────────
// Carrinho por usuário
// ─────────────────────────────────────────

model catalogo_carrinho {
  id                      Int      @id @default(autoincrement())
  usuario_id              Int
  cod_produto             String   @db.VarChar(20)
  quantidade              Int      @default(1)
  preco_carrinho_catalogo String   @default("preco2") @db.VarChar(10)
  created_at              DateTime @default(now()) @db.Timestamp()
  updated_at              DateTime @updatedAt @db.Timestamp()

  @@unique([usuario_id, cod_produto])
}

// ─────────────────────────────────────────
// Imagens de produtos
// ─────────────────────────────────────────

model catalogo_imagens {
  id          Int      @id @default(autoincrement())
  cod_produto String   @db.VarChar(20)
  url         String
  ordem       Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp()

  @@index([cod_produto])
}
